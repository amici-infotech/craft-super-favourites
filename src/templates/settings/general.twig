{# General Settings Template #}

{% extends "super-favourite/settings/_layout" %}

{% import "_includes/forms" as forms %}

{% set title = "Settings"|t('super-favourite') %}
{% set readOnly = not craft.app.config.general.allowAdminChanges %}
{% set fullPageForm = not readOnly %}
{% set selectedSettingsTab = 'general' %}

{% if readOnly %}
    {% set contentNotice = readOnlyNotice() %}
{% endif %}

{% block content %}
    {% if not readOnly %}
        {{ actionInput('super-favourite/settings/save') }}
        {{ redirectInput('super-favourite/settings/general') }}
    {% endif %}

    {{ forms.textField({
        first: true,
        label: "Plugin Name"|t('super-favourite'),
        instructions: "The name of the plugin as it appears in the Control Panel"|t('super-favourite'),
        id: 'pluginName',
        name: 'pluginName',
        value: settings.pluginName,
        errors: settings.getErrors('pluginName'),
        required: true,
        disabled: readOnly
    }) }}

    <hr>

    {{ forms.textField({
        label: "Max Collections Per User"|t('super-favourite'),
        instructions: "Maximum number of collections each user can create (0 = unlimited)"|t('super-favourite'),
        id: 'maxCollectionsPerUser',
        name: 'maxCollectionsPerUser',
        value: settings.maxCollectionsPerUser,
        type: 'number',
        min: 0,
        disabled: readOnly
    }) }}

    {{ forms.textField({
        label: "Max Favourites Per Collection"|t('super-favourite'),
        instructions: "Maximum number of favourites allowed in each collection (0 = unlimited)"|t('super-favourite'),
        id: 'maxFavouritesPerCollection',
        name: 'maxFavouritesPerCollection',
        value: settings.maxFavouritesPerCollection,
        type: 'number',
        min: 0,
        disabled: readOnly
    }) }}

{% endblock %}

