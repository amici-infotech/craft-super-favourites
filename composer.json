{
    "name": "amici/craft-super-favourite",
    "description": "A powerful wishlist/favourite plugin for Craft CMS that allows users to favourite any element type with collections support",
    "version": "5.0.0",
    "type": "craft-plugin",
    "keywords": ["craft", "cms", "craftcms", "craft-plugin", "favourite", "wishlist", "bookmark", "collections"],
    "license": "proprietary",
    "authors": [
        {
            "name": "Amici Infotech",
            "homepage": "https://amiciinfotech.com"
        }
    ],
    "support": {
        "email": "contact@amiciinfotech.com",
        "issues": "https://github.com/amici-infotech/super-favourite/issues?state=open",
        "source": "https://github.com/amici-infotech/super-favourite",
        "docs": "https://github.com/amici-infotech/super-favourite"
    },
    "require": {
        "php": "^8.0.2 || ^8.1 || ^8.2",
        "craftcms/cms": "^4.0 || ^5.0"
    },
    "autoload": {
        "psr-4": {
          "amici\\SuperFavourite\\": "src/"
        }
    },
    "extra": {
        "handle": "super-favourite",
        "name": "Super Favourite",
        "description": "A powerful wishlist/favourite plugin for Craft CMS that allows users to favourite any element type with collections support",
        "developer": "Amici Infotech",
        "developerUrl": "https://amiciinfotech.com",
        "documentationUrl": "https://github.com/amici-infotech/super-favourite",
        "changelogUrl": "https://github.com/amici-infotech/super-favourite/CHANGELOG.md",
        "class": "amici\\SuperFavourite\\Plugin"
    }
